{
  "name": "nopara",
  "version": "1.0.0",
  "type": "module",
  "description": "Secure, serverless, browser-based media conversion application with WCAG 2.2 AAA compliance and zero-trust architecture",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist --dotfiles",
    "lint": "eslint src --ext .js,.jsx",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.55.0",
    "gh-pages": "^6.3.0",
    "prettier": "^3.1.0",
    "terser": "^5.46.0",
    "vite": "^5.0.0",
    "vite-plugin-compression": "^0.5.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
