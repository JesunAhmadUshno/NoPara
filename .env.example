# NoPara Environment Configuration

# Development
VITE_APP_NAME=NoPara
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# Build
VITE_BASE_URL=/NoPara/

# Security - No external API calls
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_TELEMETRY=false
VITE_ALLOW_EXTERNAL_APIS=false

# WASM Configuration
VITE_WASM_MEMORY_PAGES=256
VITE_WASM_MAX_MEMORY_PAGES=512

# Performance
VITE_LAZY_LOAD_WASM=true
VITE_ENABLE_SERVICE_WORKER=true
VITE_CACHE_STRATEGY=network-first

# Logging
VITE_LOG_LEVEL=info
VITE_DEBUG_MODE=false
